# Copy to .env and adjust for your local dev.
#
# APP_SECRET is used to sign the bearer tokens handed out by /verify.
# Rotate it to invalidate all outstanding tokens in one go. Must be
# at least 32 characters — the TokenMinter enforces this.
APP_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Base URL the license server advertises in /verify responses as
# bundle_url and signature_url. Set to whatever the plugin can reach
# (host.docker.internal works for Moodle-in-Docker → PHP-on-host).
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Token TTL in seconds. 24h (86400) is a good default. Keep low enough
# that a leaked token expires on its own, long enough that a single
# sync never straddles the boundary.
TOKEN_TTL=86400
